# --- Data (never commit raw datasets; download via scripts) ---
# Anchor to repo root so this does NOT match the source package src/ecgcert/data/.
/data/
/upstreams
*.npy
*.npz
!results/*.npz

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.pytest-e2e-*/
.ruff_cache/
build/
dist/

# --- Results: keep figures + small JSON, ignore large dumps ---
results/**/*.pt
results/**/*.ckpt
results/cache/

# --- LaTeX ---
/texput.log
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.synctex.gz
paper/*.fdb_latexmk
paper/*.fls
# Paper PDFs are immutable evidence outputs, never source-controlled build products.
paper/*.pdf

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
scratchpad_review_*.md
scratchpad_review_*.json
scratchpad_*
.researchclaw_cache/
